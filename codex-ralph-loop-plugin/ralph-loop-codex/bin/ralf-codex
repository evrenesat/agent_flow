#!/bin/bash

set -euo pipefail

PREPARE_ONLY=0
PLAN_FILE=""
COMPLETION_PROMISE="PLAN_COMPLETE"
MAX_ITERATIONS=20
EXTRA_PROMPT_ARGS=()
STATE_FILE="ralph-loop.local.md"

usage() {
  cat <<'EOF'
Usage:
  ralf-codex [--prepare-only] [--max-iterations N] [--completion-promise TEXT] path/to/plan.md [extra instructions ...]

Options:
      --prepare-only             Write Ralph state and print the initial prompt for Codex app use.
      --max-iterations N         Maximum number of Codex Ralph iterations before the stop hook deactivates the loop.
      --completion-promise TEXT  Promise text Codex must emit to mark the run complete.
  -h, --help                    Show this help text.
EOF
}

die() {
  echo "Error: $1" >&2
  exit 1
}

while [ "$#" -gt 0 ]; do
  if [ -z "$PLAN_FILE" ]; then
    case "$1" in
      --prepare-only)
        PREPARE_ONLY=1
        shift
        ;;
      --max-iterations)
        [ "$#" -ge 2 ] || die "--max-iterations requires a value."
        MAX_ITERATIONS="$2"
        shift 2
        ;;
      --max-iterations=*)
        MAX_ITERATIONS="${1#*=}"
        shift
        ;;
      --completion-promise)
        [ "$#" -ge 2 ] || die "--completion-promise requires a value."
        COMPLETION_PROMISE="$2"
        shift 2
        ;;
      --completion-promise=*)
        COMPLETION_PROMISE="${1#*=}"
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      --)
        shift
        [ "$#" -gt 0 ] || die "Missing plan file after '--'."
        PLAN_FILE="$1"
        shift
        while [ "$#" -gt 0 ]; do
          EXTRA_PROMPT_ARGS+=("$1")
          shift
        done
        ;;
      -*)
        die "Unknown option '$1'."
        ;;
      *)
        PLAN_FILE="$1"
        shift
        while [ "$#" -gt 0 ]; do
          EXTRA_PROMPT_ARGS+=("$1")
          shift
        done
        ;;
    esac
  else
    EXTRA_PROMPT_ARGS+=("$1")
    shift
  fi
done

[ -n "$PLAN_FILE" ] || die "A plan file is required."
[ -f "$PLAN_FILE" ] || die "Plan file '$PLAN_FILE' not found."
[[ "$MAX_ITERATIONS" =~ ^[0-9]+$ ]] || die "--max-iterations must be a non-negative integer."

ABS_PLAN_PATH="$(cd "$(dirname "$PLAN_FILE")" && pwd)/$(basename "$PLAN_FILE")"
STARTED_AT="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

BASE_PROMPT="Read the plan file at ${ABS_PLAN_PATH}. Review the overall progress to understand what has already been done, then continue from where the plan was left off by finding the first unchecked checkpoint (### [ ]). Read the context, scope, and steps for that checkpoint. Execute only that checkpoint's scope. Run the required verification commands. If verification passes, update the relevant checklist items in ${ABS_PLAN_PATH}, change that checkpoint heading from ### [ ] to ### [x], and create the required git commit immediately. Re-read the plan from disk before advancing. If there are no unchecked checkpoints remaining in the file, output exactly <promise>${COMPLETION_PROMISE}</promise>. Do not output that promise unless it is completely and unequivocally true."

FINAL_PROMPT="$BASE_PROMPT"
if [ "${#EXTRA_PROMPT_ARGS[@]}" -gt 0 ]; then
  EXTRA_PROMPT="${EXTRA_PROMPT_ARGS[*]}"
  FINAL_PROMPT="${BASE_PROMPT}

${EXTRA_PROMPT}"
fi

python3 - <<'PY' "$STATE_FILE" "$MAX_ITERATIONS" "$COMPLETION_PROMISE" "$STARTED_AT" "$ABS_PLAN_PATH" "$FINAL_PROMPT"
from pathlib import Path
import json
import sys

state_path = Path(sys.argv[1])
max_iterations = sys.argv[2]
completion_promise = sys.argv[3]
started_at = sys.argv[4]
plan_path = sys.argv[5]
prompt = sys.argv[6]

content = (
    "---\n"
    "active: true\n"
    "runtime: codex\n"
    "iteration: 1\n"
    f"max_iterations: {max_iterations}\n"
    f"completion_promise: {json.dumps(completion_promise)}\n"
    f"started_at: {json.dumps(started_at)}\n"
    f"plan_path: {json.dumps(plan_path)}\n"
    "---\n\n"
    f"{prompt.rstrip()}\n"
)
state_path.write_text(content, encoding="utf-8")
PY

if [ "$PREPARE_ONLY" -eq 1 ]; then
  printf '%s\n' "$FINAL_PROMPT"
  exit 0
fi

if ! command -v codex >/dev/null 2>&1; then
  die "Required command 'codex' is not installed or not on PATH."
fi

exec codex "$FINAL_PROMPT"
