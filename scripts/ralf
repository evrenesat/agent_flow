#!/bin/bash

set -euo pipefail

DRY_RUN=0
DEFAULT_PLAN_FILE="IMPLEMENTATION_PLAN.md"
PLAN_FILE=""
COMPLETION_PROMISE="PLAN_COMPLETE"
MAX_ITERATIONS=20
DEFAULT_SETUP_SCRIPT="${HOME}/.gemini/extensions/ralph/scripts/setup.sh"
EXTRA_PROMPT_ARGS=()

usage() {
  cat <<'EOF'
Usage:
  ralf [--dry-run] [path/to/plan.md]
  ralf [--dry-run] path/to/plan.md [extra instructions ...]

Options:
      --dry-run   Print the setup and Gemini commands without executing them.
  -h, --help      Show this help text.

Environment:
  RALPH_SETUP_SCRIPT   Override the Gemini Ralph setup.sh path.
EOF
}

die() {
  echo "Error: $1" >&2
  exit 1
}

print_command() {
  printf '%q ' "$@"
  printf '\n'
}

while [ "$#" -gt 0 ]; do
  if [ -z "$PLAN_FILE" ]; then
    case "$1" in
      --dry-run)
        DRY_RUN=1
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      --)
        shift
        if [ "$#" -eq 0 ]; then
          die "Missing plan file after '--'."
        fi
        PLAN_FILE="$1"
        shift
        while [ "$#" -gt 0 ]; do
          EXTRA_PROMPT_ARGS+=("$1")
          shift
        done
        ;;
      -*)
        die "Unknown option '$1'."
        ;;
      *)
        PLAN_FILE="$1"
        shift
        while [ "$#" -gt 0 ]; do
          EXTRA_PROMPT_ARGS+=("$1")
          shift
        done
        ;;
    esac
  else
    EXTRA_PROMPT_ARGS+=("$1")
    shift
  fi
done

if [ -z "$PLAN_FILE" ]; then
  PLAN_FILE="$DEFAULT_PLAN_FILE"
fi

if [ ! -f "$PLAN_FILE" ]; then
  die "Plan file '$PLAN_FILE' not found."
fi

ABS_PLAN_PATH="$(cd "$(dirname "$PLAN_FILE")" && pwd)/$(basename "$PLAN_FILE")"
SETUP_SCRIPT="${RALPH_SETUP_SCRIPT:-$DEFAULT_SETUP_SCRIPT}"

BASE_PROMPT=$(cat <<EOF
Read the plan file at ${ABS_PLAN_PATH}. Review the overall progress to understand what has already been done, then continue from where the plan was left off by finding the first unchecked checkpoint (### [ ]). Read the context, scope, and steps for that checkpoint. Execute the work. Run the required verification commands. If verification passes, modify ${ABS_PLAN_PATH} to change that specific '### [ ]' to '### [x]'. Create a git commit. If there are no unchecked checkpoints remaining in the file, output exactly <promise>${COMPLETION_PROMISE}</promise>. Do not output that promise unless it is completely and unequivocally true.
EOF
)

FINAL_PROMPT="$BASE_PROMPT"
if [ "${#EXTRA_PROMPT_ARGS[@]}" -gt 0 ]; then
  EXTRA_PROMPT="${EXTRA_PROMPT_ARGS[*]}"
  FINAL_PROMPT="${BASE_PROMPT}

${EXTRA_PROMPT}"
fi

SETUP_COMMAND=(
  bash
  "$SETUP_SCRIPT"
  "$FINAL_PROMPT"
  --completion-promise
  "$COMPLETION_PROMISE"
  --max-iterations
  "$MAX_ITERATIONS"
)
GEMINI_COMMAND=(
  gemini
  -y
  -p
  "$FINAL_PROMPT"
)

if [ "$DRY_RUN" -eq 1 ]; then
  echo "Dry run enabled. The following commands would be executed:"
  echo ""
  print_command "${SETUP_COMMAND[@]}"
  print_command "${GEMINI_COMMAND[@]}"
  echo ""
  exit 0
fi

if ! command -v gemini >/dev/null 2>&1; then
  die "Required command 'gemini' is not installed or not on PATH."
fi

if [ ! -f "$SETUP_SCRIPT" ]; then
  die "Ralph setup script '$SETUP_SCRIPT' not found. Set RALPH_SETUP_SCRIPT if the Gemini Ralph extension is installed elsewhere."
fi

"${SETUP_COMMAND[@]}"
"${GEMINI_COMMAND[@]}"
